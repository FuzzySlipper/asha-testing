{
  "$schema": "./schemas/boundary-policy.schema.json",
  "typescript": {
    "consumerRole": "asha-testing",
    "publicSurfaceManifest": "../asha-engine/harness/public-surface/ts-packages.json"
  },
  "rust": {
    "allowedCrates": [],
    "allowedAshaPaths": [],
    "forbiddenPathFragments": [
      "../asha-engine/engine-rs/crates/foundation/",
      "../asha-engine/engine-rs/crates/state/",
      "../asha-engine/engine-rs/crates/sim/",
      "../asha-engine/engine-rs/crates/services/",
      "../asha-engine/engine-rs/crates/rules/",
      "../asha-engine/engine-rs/crates/render/",
      "../asha-engine/engine-rs/crates/bridge/native-bridge",
      "../asha-engine/engine-rs/crates/wasm/wasm-api",
      "../asha-engine/engine-rs/crates/tools/"
    ]
  },
  "pathRules": {
    "forbiddenFragments": [
      "../asha-engine/ts/packages/*/src/",
      "../asha-engine/engine-rs/crates/*/src/",
      "ts/packages/contracts/src/generated"
    ]
  },
  "remediation": "Use approved ASHA public package roots through their package exports. If the public facade cannot express the demo need, file an ASHA engine feature request or approved temporary adapter request instead of importing internals."
}
