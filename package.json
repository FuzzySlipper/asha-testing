{
  "name": "asha-testing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Synthetic public-surface regressions for ASHA; not a product acceptance repo.",
  "scripts": {
    "check:boundary": "node scripts/check-boundary.mjs",
    "synthetic": "node scripts/run-public-contract-suite.mjs",
    "synthetic:native": "ASHA_TEST_NATIVE=1 node scripts/run-public-contract-suite.mjs",
    "ci": "npm test",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs && npm run check:boundary"
  },
  "dependencies": {
    "@asha/contracts": "file:../asha-engine/ts/packages/contracts",
    "@asha/runtime-bridge": "file:../asha-engine/ts/packages/runtime-bridge"
  }
}
