{
  "name": "asha-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Boundary-proof reference consumer for ASHA public engine surfaces; not a product repo.",
  "scripts": {
    "camera:mover": "node scripts/run-camera-mover.mjs",
    "camera:agora-control": "node scripts/run-camera-agora-control.mjs",
    "asset:inventory": "node scripts/build-asset-inventory.mjs",
    "voxel:interaction": "node scripts/run-voxel-interaction.mjs",
    "check:boundary": "node scripts/check-boundary.mjs",
    "check:assets": "node scripts/check-assets.mjs",
    "check:manifest": "node scripts/check-manifest.mjs",
    "check:public-artifacts": "node scripts/check-public-artifacts.mjs",
    "ci": "npm test",
    "conformance": "node scripts/run-conformance.mjs",
    "conformance:agora": "ASHA_DEMO_AGORA_EVIDENCE=live node scripts/run-conformance.mjs",
    "dev": "node scripts/dev-runtime.mjs",
    "dev:authority-smoke": "node scripts/run-dev-authority-smoke.mjs",
    "dev:smoke": "node scripts/run-dev-smoke.mjs",
    "devtools:smoke": "node scripts/check-devtools-endpoint.mjs",
    "publish:artifact": "node scripts/build-publish-artifact.mjs",
    "publish:check": "node scripts/check-publish-artifact.mjs",
    "publish:evidence-check": "node scripts/check-publish-evidence.mjs",
    "publish:evidence": "node scripts/generate-publish-evidence.mjs",
    "publish:run-smoke": "node scripts/run-publish-run-smoke.mjs",
    "publish:smoke": "node scripts/run-publish-smoke.mjs",
    "scene:proof": "node scripts/check-proof-scenes.mjs",
    "verify:assets-v1": "node scripts/verify-assets-v1.mjs",
    "verify:workflow": "node scripts/verify-game-workflow.mjs",
    "verify:workflow:v1": "node scripts/verify-game-workflow-v1.mjs",
    "test": "node --test --test-concurrency=1 tests/*.test.mjs && npm run check:boundary"
  },
  "dependencies": {
    "@asha/contracts": "file:../asha/ts/packages/contracts",
    "@asha/devtools": "file:../asha/ts/packages/devtools",
    "@asha/game-workspace": "file:../asha/ts/packages/game-workspace",
    "@asha/runtime-bridge": "file:../asha/ts/packages/runtime-bridge"
  }
}
